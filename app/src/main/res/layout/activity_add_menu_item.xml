<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0D1B2A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Menu Item"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#F4A732"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Item Name"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="#F4A732"
        app:hintTextColor="#F4A732"
        app:boxCornerRadiusTopStart="20dp"
        app:boxCornerRadiusTopEnd="20dp"
        app:boxCornerRadiusBottomStart="20dp"
        app:boxCornerRadiusBottomEnd="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:textColor="#F5F5F5"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Price ($)"
        android:layout_marginBottom="24dp"
        app:boxStrokeColor="#F4A732"
        app:hintTextColor="#F4A732"
        app:boxCornerRadiusTopStart="20dp"
        app:boxCornerRadiusTopEnd="20dp"
        app:boxCornerRadiusBottomStart="20dp"
        app:boxCornerRadiusBottomEnd="20dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etItemPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="#F5F5F5"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#A0AEC0"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/spinner_dark_bg"
        android:paddingHorizontal="16dp"
        android:entries="@array/menu_categories"/>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbAvailable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Available for Order"
        android:checked="true"
        android:textColor="#F5F5F5"
        app:buttonTint="#F4A732"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnSaveMenu"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save Item"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0D1B2A"
        android:backgroundTint="#F4A732"
        app:cornerRadius="20dp"/>

</LinearLayout>
