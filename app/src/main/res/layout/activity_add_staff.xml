<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_staff"
            android:textColor="#F4A732"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/full_name_hint"
            android:textColorHint="#A0AEC0"
            app:boxStrokeColor="#F4A732"
            app:hintTextColor="#F4A732">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStaffName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F5F5F5" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/phone_number_hint"
            android:textColorHint="#A0AEC0"
            app:boxStrokeColor="#F4A732"
            app:hintTextColor="#F4A732">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStaffPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="#F5F5F5" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/email_hint"
            android:textColorHint="#A0AEC0"
            app:boxStrokeColor="#F4A732"
            app:hintTextColor="#F4A732">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStaffEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="#F5F5F5" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/assign_role"
            android:textColor="#A0AEC0"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerStaffRole"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="16dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/work_shift"
            android:textColor="#A0AEC0"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerStaffShift"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="16dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbStaffActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:checked="true"
            android:text="@string/account_active"
            android:textColor="#F5F5F5"
            app:buttonTint="#F4A732" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveStaff"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:text="@string/add_member"
            android:textAllCaps="false"
            android:textColor="#0D1B2A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#F4A732"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
